{
  "name": "redshield",
  "version": "1.0.0",
  "description": "REDSHIELD — Scanner de sécurité réseau WiFi",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build:python": "cd backend && pyinstaller --onefile --name server server.py --hidden-import=eventlet --hidden-import=flask_socketio --add-data \"vuln_db;vuln_db\"",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "devDependencies": {
    "electron": "^22.3.27",
    "electron-builder": "^24.9.0"
  }
}
